# ─────────────────────────────────────────
#  OgaPay Backend — Environment Variables
#  Copy this to .env and fill in values
# ─────────────────────────────────────────

# Server
NODE_ENV=development
PORT=5000
API_VERSION=v1

# JWT
JWT_SECRET=your_super_secret_jwt_key_min_32_chars
JWT_EXPIRES_IN=7d
JWT_REFRESH_SECRET=your_refresh_secret_key
JWT_REFRESH_EXPIRES_IN=30d

# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key
SUPABASE_KYC_BUCKET=Kyc-Documents
SUPABASE_PROOF_BUCKET=task-proofs

# Database (PostgreSQL via Supabase)
DATABASE_URL=postgresql://postgres:password@db.your-project.supabase.co:5432/postgres?pgbouncer=true&connection_limit=1
DIRECT_URL=postgresql://postgres:password@db.your-project.supabase.co:5432/postgres

# KYC — Dojah (Nigerian KYC provider)
DOJAH_APP_ID=your_dojah_app_id
DOJAH_SECRET_KEY=your_dojah_secret_key
DOJAH_BASE_URL=https://api.dojah.io

# KYC — Smile Identity (Alternative)
SMILE_PARTNER_ID=your_smile_partner_id
SMILE_API_KEY=your_smile_api_key

# Paystack (NGN payments)
PAYSTACK_SECRET_KEY=sk_live_your_paystack_secret
PAYSTACK_PUBLIC_KEY=pk_live_your_paystack_public
PAYSTACK_WEBHOOK_SECRET=your_webhook_secret

# Flutterwave (NGN payments alternative)
FLUTTERWAVE_SECRET_KEY=FLWSECK_your_key
FLUTTERWAVE_PUBLIC_KEY=FLWPUBK_your_key
FLUTTERWAVE_WEBHOOK_SECRET=your_flw_webhook_secret

# Crypto — Web3 / Alchemy
ALCHEMY_API_KEY=your_alchemy_api_key
ALCHEMY_NETWORK=matic-mainnet
PLATFORM_WALLET_ADDRESS=0x_your_platform_wallet
PLATFORM_WALLET_PRIVATE_KEY=your_encrypted_private_key

# Solana (x402 funding)
SOLANA_RPC_URL=https://api.mainnet-beta.solana.com
# PLATFORM_WALLET_PRIVATE_KEY reused for Solana platform keypair (must be Solana base58 private key)

# Email (Resend)
RESEND_API_KEY=re_your_resend_api_key
EMAIL_FROM=noreply@ogapay.io

# SMTP fallback (used when Resend fails)
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your_email@gmail.com
# SMTP_PASS=your_app_password

# AI task copy proxy
ANTHROPIC_API_KEY=sk-ant-your-key
ANTHROPIC_MODEL=claude-3-5-sonnet-latest

# Redis (for queues + caching)
REDIS_URL=redis://localhost:6379

# Optional production queue/cache provider for Vercel
UPSTASH_REDIS_REST_URL=https://your-upstash-url
UPSTASH_REDIS_REST_TOKEN=your-upstash-token

# Twitter OAuth 2.0 (PKCE) — Developer Portal
TWITTER_CLIENT_ID=your_twitter_client_id
TWITTER_CLIENT_SECRET=your_twitter_client_secret
TWITTER_CALLBACK_URL=https://ogapay-production.up.railway.app/api/v1/twitter/callback

# App
FRONTEND_URL=https://ogapay-five.vercel.app
PLATFORM_FEE_PERCENT=10
MAX_FILE_SIZE_MB=10
