# ─────────────────────────────────────────
#  OgaPay Backend — Environment Variables
#  Copy this to .env and fill in values
# ─────────────────────────────────────────

# Server
NODE_ENV=development
PORT=5000
API_VERSION=v1

# JWT
JWT_SECRET=your_super_secret_jwt_key_min_32_chars
JWT_EXPIRES_IN=7d
JWT_REFRESH_SECRET=your_refresh_secret_key
JWT_REFRESH_EXPIRES_IN=30d

# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# Database (PostgreSQL via Supabase)
DATABASE_URL=postgresql://postgres:password@db.your-project.supabase.co:5432/postgres

# KYC — Dojah (Nigerian KYC provider)
DOJAH_APP_ID=your_dojah_app_id
DOJAH_SECRET_KEY=your_dojah_secret_key
DOJAH_BASE_URL=https://api.dojah.io

# KYC — Smile Identity (Alternative)
SMILE_PARTNER_ID=your_smile_partner_id
SMILE_API_KEY=your_smile_api_key

# Paystack (NGN payments)
PAYSTACK_SECRET_KEY=sk_live_your_paystack_secret
PAYSTACK_PUBLIC_KEY=pk_live_your_paystack_public
PAYSTACK_WEBHOOK_SECRET=your_webhook_secret

# Flutterwave (NGN payments alternative)
FLUTTERWAVE_SECRET_KEY=FLWSECK_your_key
FLUTTERWAVE_PUBLIC_KEY=FLWPUBK_your_key
FLUTTERWAVE_WEBHOOK_SECRET=your_flw_webhook_secret

# Crypto — Web3 / Alchemy
ALCHEMY_API_KEY=your_alchemy_api_key
ALCHEMY_NETWORK=matic-mainnet
PLATFORM_WALLET_ADDRESS=0x_your_platform_wallet
PLATFORM_WALLET_PRIVATE_KEY=your_encrypted_private_key

# Email (Resend or SendGrid)
RESEND_API_KEY=re_your_resend_api_key
EMAIL_FROM=noreply@ogapay.io

# Redis (for queues + caching)
REDIS_URL=redis://localhost:6379

# App
FRONTEND_URL=https://ogapay.io
PLATFORM_FEE_PERCENT=10
MAX_FILE_SIZE_MB=10
